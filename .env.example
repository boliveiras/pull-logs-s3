# Copie para .env e ajuste. O script carrega o .env da própria pasta.
#
# SEGURANÇA: este arquivo pode conter chaves AWS. Tranque o acesso:
#   Linux:   chmod 640 .env   (dono root, grupo da conta de serviço)
#   Windows: ACL liberando leitura só p/ SYSTEM, Admin e a conta de serviço
# Veja a seção "Segurança da instalação" no README. Nunca faça commit do .env.

# --- AWS / S3 ---
# Use uma IAM Role/instance profile quando possível. Se precisar de chaves,
# defina-as como variáveis de ambiente padrão do AWS SDK (NÃO commite isso):
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=your-s3-logs-bucket

# --- Caminhos locais ---
# PULL_BASE_DIR: onde os .gz baixados ficam (área temporária).
# PULL_LOG_DIR:  onde os .log prontos ficam — é ESTA pasta que o agente lê.
PULL_BASE_DIR=D:/Logs
PULL_LOG_DIR=D:/Logs/Tecnologia
PULL_STATE_FILE=D:/Logs/ultima_sincronizacao.txt
PULL_EXEC_LOG=C:/LogFiles/pull-logs-s3/sync_execution.log

# --- Comportamento ---
# Prefixo do S3 (strftime em UTC). Muitas fontes organizam os logs por data.
S3_PREFIX_TEMPLATE=%Y%m%d/
# Intervalo entre ciclos no modo loop (segundos).
PULL_INTERVAL_SECONDS=60
