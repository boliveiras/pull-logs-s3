# Copie para .env e ajuste. Carregue as variáveis no ambiente antes de rodar
# o script (ou configure-as no serviço/Agendador de Tarefas do Windows).

# --- AWS / S3 ---
# Use uma IAM Role/instance profile quando possível. Se precisar de chaves,
# defina-as como variáveis de ambiente padrão do AWS SDK (NÃO commite isso):
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
CF_BUCKET=your-cloudflare-logs-bucket

# --- Caminhos locais ---
CF_BASE_DIR=D:/Cloudflare
CF_LOG_DIR=D:/Cloudflare/Logs
CF_STATE_FILE=D:/Cloudflare/ultima_sincronizacao.txt
CF_EXEC_LOG=C:/LogFiles/Cloudflare/sync_execution.log

# --- Comportamento ---
# Prefixo do S3 (strftime em UTC). Cloudflare Logpush costuma organizar por data.
CF_PREFIX_TEMPLATE=%Y%m%d/
# Intervalo entre ciclos no modo loop (segundos).
CF_INTERVAL_SECONDS=60
